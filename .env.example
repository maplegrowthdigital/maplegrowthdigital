# Email Configuration — Resend
# Required for the contact form (/api/contact) to send email.
# Get your API key at https://resend.com/api-keys

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are delivered
CONTACT_FORM_TO=info@yourdomain.com

# Sender shown on outbound emails. The domain must be verified in Resend.
# If unset (or the domain isn't verified yet), the route auto-falls-back to
# Resend's sandbox sender (onboarding@resend.dev).
CONTACT_FORM_FROM="Your Brand <no-reply@yourdomain.com>"

# Optional — Cloudflare Turnstile CAPTCHA (server-side verification)
# If set, the /api/contact route will require a valid token from the client.
# TURNSTILE_SECRET_KEY=

# Analytics (Optional)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
