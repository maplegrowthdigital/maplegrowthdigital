# Email Configuration — Hostinger SMTP
# Required for the contact form (/api/contact) to send email.

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@yourdomain.com
SMTP_PASS=your_mailbox_password

# Where contact-form submissions are delivered
CONTACT_FORM_TO=info@yourdomain.com

# From-address shown on outbound emails. Must match SMTP_USER or one of its aliases.
CONTACT_FORM_FROM="Your Brand <info@yourdomain.com>"

# Optional — Cloudflare Turnstile CAPTCHA (server-side verification).
# If set, the /api/contact route will require a valid token from the client.
# TURNSTILE_SECRET_KEY=

# Analytics (Optional)
# Google Tag Manager ID (format: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google Analytics ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
